# Copia a `.env` i ajusta la IP pública del servidor (per certificat HTTPS autofirmat)
PROFES_TLS_SAN_IP=46.225.28.149

# Opcional
# PROFES_HTTP_PORT=9088
# PROFES_HTTPS_PORT=9443

# Feature 0 — ruta POST /api/feature0/analysis/llm (Vite dev / preview, servidor Node; no al navegador)
# Copia aquestes línies a apps/frontend/.env.local (no versionar) o exporta-les al shell abans de npm run dev.
# FEATURE0_OPENAI_API_KEY=
# Opcional: endpoint compatible OpenAI (per defecte https://api.openai.com/v1)
# FEATURE0_OPENAI_BASE_URL=https://api.openai.com/v1
# FEATURE0_OPENAI_MODEL=gpt-4o-mini
# Alternativa: OPENAI_API_KEY (si no uses FEATURE0_OPENAI_API_KEY)

# Feature 2 — Assessment Spec Builder (mateix patró: apps/frontend/.env.local)
# ASSESSMENT_SPEC_OPENAI_API_KEY=
# ASSESSMENT_SPEC_OPENAI_BASE_URL=https://api.openai.com/v1
# Passada 1 (base / extracció) i passada 2 (enriqueiment pedagògic) poden usar models diferents:
# ASSESSMENT_SPEC_MODEL=gpt-5.4-mini
# ASSESSMENT_SPEC_ENRICH_MODEL=gpt-5.4
# Experimental (passada 2): gpt-5.4-pro → client usa POST /v1/responses
# Legacy: un sol model per ambdues passades si no defines ASSESSMENT_SPEC_MODEL / _ENRICH_:
# ASSESSMENT_SPEC_OPENAI_MODEL=gpt-4o-mini
# En dev, el servidor també accepta FEATURE0_OPENAI_API_KEY si les anteriors no s’han definit.
# Calibratge hospital (2 variants per defecte): npm run calibration:assessment-spec-models -w @profes/frontend
