{
  "name": "@profes/frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "spike:qae": "tsx --tsconfig tsconfig.app.json scripts/questionAnswerSpike.ts",
    "smoke:qae-facade": "tsx --tsconfig tsconfig.app.json scripts/qaeFacadeSmoke.ts",
    "dev:qae-api": "tsx --tsconfig tsconfig.app.json scripts/qaeLocalApiServer.ts",
    "benchmark:ocr": "tsx --tsconfig tsconfig.app.json scripts/ocrBenchmark.ts"
  },
  "dependencies": {
    "busboy": "^1.6.0",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tesseract.js": "^7.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/busboy": "^1.5.4",
    "@types/node": "^22.13.10",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.21.0",
    "typescript": "~5.7.3",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.3.5",
    "vitest": "^3.0.9"
  }
}
